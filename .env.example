# ── gtm-research — BYOK environment ──────────────────────────────────────────
# Copy this file to `.env` and fill in ONLY what you have. Secrets are read from
# your LOCAL environment only — this engine NEVER fetches a key over the network.
# Load them before invoking, e.g.:
#
#     set -a && source .env && set +a
#
# Do NOT commit your `.env` (it is gitignored). Every rung auto-skips when its key
# is absent, so a partial key set still gives a working, cheaper waterfall. The
# minimum viable setup is ZERO keys: the free DuckDuckGo + native-fetch rungs work
# with nothing set (Tavily/Exa/Parallel/digest simply don't fire).

# ── Telemetry + cache database (OPTIONAL) ────────────────────────────────────
# A Postgres DSN — LOCAL or hosted. Unset = run with no cache / no telemetry.
# Local:   postgresql://localhost:5432/gtm_research
# Hosted:  postgresql://user:pass@host:5432/dbname?sslmode=require
# Falls back to DATABASE_URL (so it shares a gtm-pipeline database when dropped in).
RESEARCH_DATABASE_URL=

# ── Free search rungs (no key needed for DuckDuckGo) ─────────────────────────
BRAVE_API_KEY=            # Brave Search API — free ~2k/mo
SERPER_API_KEY=           # Serper.dev — free ~2.5k/mo

# ── Semantic discovery (optional) ────────────────────────────────────────────
EXA_API_KEY=              # Exa neural search — free ~1k/mo; the semantic discovery rung

# ── Page fetch rungs ─────────────────────────────────────────────────────────
JINA_API_KEY=             # Jina Reader (r.jina.ai) — works KEYLESS; a key lifts 20rpm -> 500rpm
TAVILY_API_KEY=           # Tavily Extract + Search — the paid escalation (credits)

# ── Gated last-resort (optional, ~$0.005/req after a one-time free tier) ──────
PARALLEL_API_KEY=         # Parallel.ai Search/Extract — only fires with --allow-parallel

# ── Long-page compression (optional) ─────────────────────────────────────────
OPENROUTER_API_KEY=       # compresses pages >8K chars to quoted facts (page-digest)
# RESEARCH_DIGEST_MODEL=deepseek/deepseek-chat   # override the digest model

# ── Misc (optional) ──────────────────────────────────────────────────────────
# RESEARCH_CACHE_DIR=/tmp           # where the Tavily cooldown marker is written
# TAVILY_COOLDOWN_SECS=3600         # how long to skip Tavily after a credit/rate-limit response
# RESEARCH_CLAUDE_CLI_MODEL=claude-haiku-4-5   # model for the optional claude_cli search rung
